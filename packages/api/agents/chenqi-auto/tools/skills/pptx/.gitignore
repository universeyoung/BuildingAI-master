# Bootstrap-installed runtime artifacts (regenerated by bootstrap.sh on demand).
# node_modules is platform/Node-ABI specific and MUST NOT be committed.
# package-lock.json IS committed — it pins the full transitive dependency tree
# so every machine resolves the exact same versions.
node_modules/

# Workspace output (per-task scratch dirs created by html2pptx workflow)
workspace/

# Common temporary files
*.log
.DS_Store
